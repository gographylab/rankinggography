# =====================================================================
# Copy this file to `.env.local` and fill in the values.
# `.env.local` is gitignored — never commit real credentials.
# =====================================================================

# ---------- Public (exposed to browser) ----------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-public-key...
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------- Server-only (NEVER commit) ----------
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your-service-role-key...

# OAuth (configure in Supabase dashboard; included here for reference only)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=noreply@gography.net
EMAIL_REPLY_TO=hello@gography.net

# Cron auth header
CRON_SECRET=

# Optional: error tracking
SENTRY_DSN=
